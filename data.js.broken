const examData = {
    topics: [
        {
            id: 't1', title: '1. Generativ AI vs Traditionell AI', desc: 'Vad är GenAI och hur genereras svar?', level: 'g',
            theory: [
                '**GenAI** skapar *nytt innehåll* baserat på mönster.',
                '**Traditionell AI** klassificerar, sorterar eller förutsäger (ex. spamfilter).',
                '**Probabilistisk:** LLM:er gissar nästa token utifrån sannolikhet. De "vet" inte sanningen.',
                '**Autoregressiv generering:** Modellen skapar ett ord i taget, det nya ordet blir kontext för nästa.'
            ],
            keyConcepts: ['Probabilistisk', 'Autoregressiv', 'LLM', 'Context window']
        },
        {
            id: 't2', title: '2. Data → Information → Kunskap', desc: 'Kunskapstransformation i organisationer.', level: 'g',
            theory: [
                '**Data:** Råa observationer (loggar, siffror).',
                '**Information:** Strukturerad data i en kontext (t.ex. klagomål = vanligaste felet X).',
                '**Kunskap:** Tolkning + beslut (Vad gör vi åt det?).',
                '**AI:s roll:** AI är fantastisk på data → information (sammanfatta, strukturera), men osäker på information → kunskap (kräver omdöme).'
            ],
            keyConcepts: ['Datamognad', 'Tolkningsförmåga', 'Mänskligt omdöme']
        },
        {
            id: 't3', title: '3. Hallucinationer & Risker', desc: 'Varför de uppstår och hur vi skyddar oss.', level: 'g',
            theory: [
                '**Hallucinationer** uppstår för att modellen hittar den mest *sannolika* fortsättningen rent språkligt, även om faktan är fel.',
                '**Bias/Partiskhet:** LLMs speglar de snedvridningar som finns i internets historiska träningsdata.',
                '**Prompt Injection:** Skadliga instruktioner dolda i dokument/hemsidor som agenten läser.'
            ],
            keyConcepts: ['Hallucination', 'Prompt Injection', 'Bias', 'Temperature']
        },
        {
            id: 't4', title: '4. Verktyg (Tools) och MCP', desc: 'Hur LLM:er interagerar med omvärlden.', level: 'g',
            theory: [
                '**Tool:** En definierad funktion systemet kan köra å modellens vägnar (ex. hämta väder, läsa databas).',
                '**RAG:** (Retrieval-Augmented Generation). Hämta relevant text via *embeddings* och *chunking* → skicka in i prompten → generera svar.',
                '**MCP:** Standardiserar hur verktyg fungerar (Model Context Protocol).',
                '**VIKTIGT:** Modellen kör aldrig koden själv, den *ber systemet* göra det.'
            ],
            keyConcepts: ['RAG', 'Chunking', 'Embeddings', 'MCP', 'Tool Calling']
        },
        {
            id: 't5', title: '5. AI-agenter', desc: 'Från passiv chatt till problemlösning.', level: 'vg',
            theory: [
                'En agent löser problem iterativt: **Tolka → Resonera → Agera → Observera → Upprepa.**',
                'Det som gör en agent är en LLM + Planering + Minne + Verktyg.',
                '**Deterministisk (Regel) vs Icke-Deterministisk (AI):** En agent har varians och kan hantera oväntade inputs, regler kraschar vid undantag.'
            ],
            keyConcepts: ['Agentloopen', 'Varians', 'Definition of Done']
        },
        {
            id: 't6', title: '6. Multi-agent-system (Patterns)', desc: 'Designmönster för multipla agenter.', level: 'vg',
            theory: [
                '**Handoff (Sekventiellt):** A → B → C. Stafettpinne, bra för linjära flöden.',
                '**Supervisor:** Central manager distribuerar arbete till experter. Kan bli en flaskhals.',
                '**Planner-Doer-Critic:** Fokus på *kvalitetssäkring*. Planner gör plan, Doer utför, Critic granskar resultatet mot kraven.',
                '**Hybrid:** Blandar klassiska `if-else` regler (för API-validering) med Agenter (för tolkning).'
            ],
            keyConcepts: ['Handoff', 'Supervisor', 'Planner-Doer-Critic', 'Hybrid-flöden']
        },
        {
            id: 't7', title: '7. Kommunikationsöverlämning', desc: 'Vad nästa agent behöver veta.', level: 'vg',
            theory: [
                'Lämna aldrig hela chathistoriken. Sammanfatta istället kontexten strukturerat.',
                'Bra överlämning innehåller: Mål, Constraints (regler), Kända fakta, Öppna frågor, Format.',
                '**Cascading errors:** Ett överlämningsfel i steg 1 förstärks och blir en absolut "sanning" i steg 3.'
            ],
            keyConcepts: ['Handoff-payload', 'Cascading errors', 'State-objekt']
        },
        {
            id: 't8', title: '8. Governance & Säkerhet', desc: 'Hur man säkrar AI-system.', level: 'vg',
            theory: [
                '**Least Privilege:** Ge aldrig en klassificerings-agent rättigheter att skicka kundmejl.',
                '**Human-in-the-loop (HITL):** Människa måste godkänna handling innan verkställning, vid högriskbeslut (ex. finansiellt).',
                'Verktygsoutput = **Osäker Input**. Måste hanteras med misstänksamhet.',
                'Governance handlar om att spåra *varför* systemet fattade ett beslut (Audit logs).'
